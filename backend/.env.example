# Copy this file to `.env` and fill in the values.
# The defaults are set up to work out-of-the-box with OpenRouter's free tier.

# --- Active provider (must match a key in the provider config) ---
ACTIVE_PROVIDER=openrouter
ACTIVE_MODEL=meta-llama/llama-3-8b-instruct:free

# --- API keys (leave unused ones blank) ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/cs732_chatbot

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Advanced: local HuggingFace models (Phase 2, optional) ---
ENABLE_LOCAL_MODELS=false
